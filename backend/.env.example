DB_HOST=localhost
DB_PORT=5432
DB_NAME=datapilot
DB_USER=datapilot_user
DB_PASSWORD=YOUR_STRONG_PASSWORD
JWT_SECRET=your-random-secret-key-here
ALLOWED_ORIGINS=https://your-app.vercel.app

# Optional — Kaggle dataset URL support (kaggle.com -> Account -> API -> Create New Token)
KAGGLE_USERNAME=
KAGGLE_KEY=

# Optional — Private Google Sheets support (Google Cloud Console -> Service Account -> JSON key)
# Share the target sheet with the service account's "client_email" found inside the JSON file.
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
