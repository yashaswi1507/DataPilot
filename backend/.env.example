DB_HOST=localhost
DB_PORT=5432
DB_NAME=datapilot
DB_USER=datapilot_user
DB_PASSWORD=YOUR_STRONG_PASSWORD
JWT_SECRET=your-random-secret-key-here
ALLOWED_ORIGINS=https://your-app.vercel.app

# Email sending (forgot-password, team invites) — uses Gmail SMTP.
# 1. Enable 2-Step Verification on the Gmail account: myaccount.google.com/security
# 2. Generate an App Password: myaccount.google.com/apppasswords
# 3. Paste the 16-character password below (no spaces)
# If left blank, forgot-password/invite still work — the reset/invite
# link is shown directly in the response instead of being emailed.
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Google OAuth — "Continue with Google" login/signup
# Get this from Google Cloud Console -> APIs & Services -> Credentials
# Must match the client ID hardcoded in frontend/src/components/ui/GoogleSignInButton.jsx
GOOGLE_CLIENT_ID=544303241286-stc79gugvrb30kv9v8to3ga0rop6e6vl.apps.googleusercontent.com

# Optional — Kaggle dataset URL support (kaggle.com -> Account -> API -> Create New Token)
KAGGLE_USERNAME=
KAGGLE_KEY=

# Optional — Private Google Sheets support (Google Cloud Console -> Service Account -> JSON key)
# Share the target sheet with the service account's "client_email" found inside the JSON file.
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
