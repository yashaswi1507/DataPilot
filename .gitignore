# Environment files with secrets — NEVER commit these
.env
.env.local
.env.production.local
.env.development.local
backend/.env

# Build outputs
frontend/dist/
frontend/build/

# Saved ML models (can be large, regenerated by training)
backend/saved_models/*.pkl

# Logs
*.log

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Vercel
.vercel/
